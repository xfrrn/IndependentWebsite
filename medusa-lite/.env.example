# Local host tools use the published Postgres port from docker-compose.yml.
DATABASE_URL="postgres://medusa:change-me@localhost:5434/medusa_lite?sslmode=disable"

# Docker Compose database settings.
POSTGRES_USER="medusa"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="medusa_lite"

# App URL.
# Local: http://localhost:7890
# Server: change this to https://your-domain.com before docker compose prod build.
NEXT_PUBLIC_BASE_URL="http://localhost:7890"

# Admin and content secrets.
CONTENT_ADMIN_SECRET="change-me"
CONTENT_MANAGER_KEY="change-me"
LITE_ADMIN_EMAIL="admin@example.com"
LITE_ADMIN_PASSWORD="change-me"
LITE_ADMIN_SESSION_SECRET="change-me"
REVALIDATE_SECRET="change-me"

# Optional social links.
NEXT_PUBLIC_FACEBOOK_URL=""
NEXT_PUBLIC_INSTAGRAM_URL=""

# Runtime.
NODE_ENV="development"
AUTO_MIGRATE="true"
AUTO_SEED="true"
