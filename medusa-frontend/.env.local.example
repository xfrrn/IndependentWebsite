# Local Medusa backend URL. Update backend CORS when changing this.
MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable key attached to the storefront sales channel.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_replace_me

# Local storefront URL.
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Default storefront region country code.
NEXT_PUBLIC_DEFAULT_REGION=dk

# Optional payment env values.
NEXT_PUBLIC_STRIPE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=

# Next.js revalidation secret.
REVALIDATE_SECRET=supersecret

# Optional image optimization settings for hosted uploads.
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=

# Optional content manager access key.
CONTENT_MANAGER_KEY=

# Optional backend secret used when saving editable storefront content.
CONTENT_ADMIN_SECRET=
