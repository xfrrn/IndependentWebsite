# Domains
PRIMARY_DOMAIN=kidgofun.com
SECONDARY_DOMAIN=ttgo.shop

# Public URLs. Pick one canonical storefront URL.
NEXT_PUBLIC_BASE_URL=https://kidgofun.com
STOREFRONT_BASE_URL=https://kidgofun.com

# Storefront region and Medusa publishable key.
# Create the publishable key in Medusa Admin and paste it here before building.
NEXT_PUBLIC_DEFAULT_REGION=dk
DEFAULT_STORE_COUNTRY_CODE=dk
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_live_replace_me
ENABLE_DEV_PUBLISHABLE_KEY_ENDPOINT=false
AUTO_MIGRATE=false
AUTO_SEED=false
AUTO_ADMIN_USER=false

# CORS. Keep both domains here if both should serve the same site.
STORE_CORS=https://kidgofun.com,https://www.kidgofun.com,https://ttgo.shop,https://www.ttgo.shop
ADMIN_CORS=https://kidgofun.com,https://www.kidgofun.com,https://ttgo.shop,https://www.ttgo.shop
AUTH_CORS=https://kidgofun.com,https://www.kidgofun.com,https://ttgo.shop,https://www.ttgo.shop

# Database and Redis. Replace every placeholder.
POSTGRES_USER=medusa
POSTGRES_PASSWORD=replace_with_strong_random_password
POSTGRES_DB=medusa_db
REDIS_PASSWORD=replace_with_strong_random_password

# Server secrets. Generate each with: openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars
COOKIE_SECRET=replace_with_64_hex_chars
CONTENT_ADMIN_SECRET=replace_with_64_hex_chars
CONTENT_MANAGER_KEY=replace_with_long_random_admin_key
REVALIDATE_SECRET=replace_with_64_hex_chars
